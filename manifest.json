{
	"manifest_version": 3,
	"name": "Light Off",
	"version": "1.0.0",
	"description": "Change the tab brightness easily.",
	"permissions": ["activeTab", "scripting", "storage"],
	"action": {
		"default_popup": "index.html",
		"default_title": "Light Off",
		"default_icon": {
			"16": "icons/icon.png",
			"32": "icons/icon.png",
			"48": "icons/icon.png",
			"128": "icons/icon.png"
		}
	},
	"icons": {
		"16": "icons/icon.png",
		"32": "icons/icon.png",
		"48": "icons/icon.png",
		"128": "icons/icon.png"
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["content.js"],
			"run_at": "document_start",
			"all_frames": true
		}
	],
	"host_permissions": ["<all_urls>"]
}
